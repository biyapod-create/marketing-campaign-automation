# ============================================================
# .env.example — Copy this to .env and fill in your values
# NEVER commit the actual .env file
# ============================================================

# ── Apollo.io ───────────────────────────────────────────────
# Get your key at: https://app.apollo.io/ → Settings → API
APOLLO_IO_API_KEY=your_apollo_api_key_here

# ── SMTP / Email Sending ─────────────────────────────────────
# Your outbound email server credentials
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=info@yourdomain.com
SMTP_PASS=your_smtp_password_here

# ── Sender Identity (used in email signatures & templates) ──
SENDER_NAME=Your Company Ltd
SENDER_PHONE=+1 (555) 000-0000
SENDER_WEBSITE=www.yourdomain.com

# ── Anthropic (Claude AI — used by WhatsApp bot) ────────────
# Get your key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
